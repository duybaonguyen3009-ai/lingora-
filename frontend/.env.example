# ─── API URL ──────────────────────────────────────────────────────────────────
# Local development: point directly at the Express server.
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# Production (Vercel): use the Next.js proxy rewrite so SameSite=Strict
# refresh-token cookies are sent correctly (same origin as the frontend).
# Set this in your Vercel environment variables:
#   NEXT_PUBLIC_API_URL=/api/v1
#
# The Next.js rewrite in next.config.mjs will forward /api/v1/* requests
# to BACKEND_URL (set below) server-side.

# ─── Backend URL (server-only — never exposed to the browser) ─────────────────
# Used by next.config.mjs rewrites() to forward requests to Railway.
# Example: https://lingora-api-production.up.railway.app
# Leave as-is for local dev (the proxy still works but isn't needed).
BACKEND_URL=http://localhost:4000

# ─── Sentry (optional) ────────────────────────────────────────────────────────
# NEXT_PUBLIC_SENTRY_DSN is safe to expose — it's a public ingestion key.
# Leave blank in local dev to disable Sentry.
# NEXT_PUBLIC_SENTRY_DSN=https://xxxx@oxxxx.ingest.sentry.io/xxxx

# Required for source-map upload during `next build` (Vercel CI only).
# Generate at: https://sentry.io/settings/account/api/auth-tokens/
# SENTRY_AUTH_TOKEN=sntrys_xxxx
# SENTRY_ORG=your-sentry-org-slug
# SENTRY_PROJECT=lingora-frontend
