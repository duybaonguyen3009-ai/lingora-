# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://localhost:5432/lingora_dev

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ─── JWT  (added in Phase 1 Task 2 – auth endpoints) ─────────────────────────
# JWT_ACCESS_SECRET=change-me-to-a-long-random-string
# JWT_REFRESH_SECRET=change-me-to-a-different-long-random-string
# JWT_ACCESS_EXPIRES_IN=15m
# JWT_REFRESH_EXPIRES_IN=30d

# ─── Providers (Phase 3 — Pronunciation Practice) ────────────────────────────
# STORAGE_PROVIDER=mock          # mock | r2
# SPEECH_PROVIDER=mock           # mock | azure

# ─── Cloudflare R2 (when STORAGE_PROVIDER=r2) ───────────────────────────────
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=lingora-audio
# R2_PUBLIC_URL=https://audio.lingora.app

# ─── Azure Speech (when SPEECH_PROVIDER=azure) ──────────────────────────────
# AZURE_SPEECH_KEY=
# AZURE_SPEECH_REGION=eastus

# ─── Sentry  (optional — error tracking) ──────────────────────────────────────
# Leave blank in local dev. Set in Railway environment variables for production.
# SENTRY_DSN=https://xxxx@oxxxx.ingest.sentry.io/xxxx
